# Runtime environment for the container (compose reads this as env_file).
# Copy to config/enfilera.env and set your real token. config/enfilera.env is
# gitignored — never commit the token.
#
#   cp config/enfilera.env.example config/enfilera.env

# Bot token from @BotFather. The variable NAME must match [bot].token_env in
# config/config.toml (default: ENFILERA_BOT_TOKEN).
ENFILERA_BOT_TOKEN=123456789:fake-telegram-bot-token-from-botfather

# Optional overrides (the image already points these at the mounted paths;
# uncomment only to change them):
# ENFILERA_CONFIG=/app/config/config.toml
# ENFILERA_DB=/app/data/enfilera.db
